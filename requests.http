@base = http://localhost:8000/api


# =============================================
# CHARACTERS
# =============================================

### Get all characters
GET {{base}}/characters

### Get all characters (labels only)
GET {{base}}/characters?allData=false

### Get characters filtered by race
GET {{base}}/characters?pred=race&obj=Hobbit

### Get characters filtered by race (labels only)
GET {{base}}/characters?pred=race&obj=Hobbit&allData=false

### Get characters filtered by affiliation
GET {{base}}/characters?pred=affiliation&obj=FellowshipOfTheRing

### Get characters filtered by affiliation (labels only)
GET {{base}}/characters?pred=affiliation&obj=FellowshipOfTheRing&allData=false

### Get character by name
GET {{base}}/characters/Gandalf

### Get character by name (not found)
GET {{base}}/characters/Gollum

### Add character
POST {{base}}/characters
Content-Type: application/json

{
  "name": "Boromir",
  "givenName": "Boromir",
  "familyName": "Denethor",
  "race": "Human",
  "birthplace": "MinasTirith",
  "affiliation": ["Gondor", "FellowshipOfTheRing"]
}

### Add character - conflict (already exists)
POST {{base}}/characters
Content-Type: application/json

{
  "name": "Frodo",
  "race": "Hobbit"
}

### Add character - invalid race
POST {{base}}/characters
Content-Type: application/json

{
  "name": "Smaug",
  "race": "Dragon"
}

### Update character
PUT {{base}}/characters/Boromir
Content-Type: application/json

{
  "name": "Boromir",
  "alternateName": ["Son of Denethor"],
  "affiliation": ["Gondor"]
}

### Update character - not found
PUT {{base}}/characters/Gollum
Content-Type: application/json

{
  "name": "Gollum"
}


# =============================================
# RACES
# =============================================

### Get all races
GET {{base}}/races

### Get all races (labels only)
GET {{base}}/races?allData=false

### Get races filtered by longevity
GET {{base}}/races?pred=longevity&obj=9999

### Get races filtered by longevity (labels only)
GET {{base}}/races?pred=longevity&obj=9999&allData=false

### Get race by name
GET {{base}}/races/Hobbit

### Get race by name (not found)
GET {{base}}/races/Dragon

### Add race
POST {{base}}/races
Content-Type: application/json

{
  "name": "Ent",
  "longevity": 10000,
  "knowsLanguage": "Entish"
}

### Add race - conflict (already exists)
POST {{base}}/races
Content-Type: application/json

{
  "name": "Elf"
}

### Update race
PUT {{base}}/races/Ent
Content-Type: application/json

{
  "name": "Ent",
  "longevity": 5000
}


# =============================================
# PLACES
# =============================================

### Get all places
GET {{base}}/places

### Get all places (labels only)
GET {{base}}/places?allData=false

### Get places filtered by faction
GET {{base}}/places?pred=territoryOf&obj=Mordor

### Get places filtered by faction (labels only)
GET {{base}}/places?pred=territoryOf&obj=Mordor&allData=false

### Get place by name
GET {{base}}/places/Shire

### Get place by name (not found)
GET {{base}}/places/Mordor

### Add place
POST {{base}}/places
Content-Type: application/json

{
  "name": "Erebor",
  "territoryOf": "FellowshipOfTheRing"
}

### Add place - invalid faction
POST {{base}}/places
Content-Type: application/json

{
  "name": "Rivendell",
  "territoryOf": "Istari"
}

### Update place
PUT {{base}}/places/Erebor
Content-Type: application/json

{
  "name": "Erebor",
  "territoryOf": "Gondor"
}


# =============================================
# FACTIONS
# =============================================

### Get all factions
GET {{base}}/factions

### Get all factions (labels only)
GET {{base}}/factions?allData=false

### Get factions filtered by ally
GET {{base}}/factions?pred=ally&obj=Rohan

### Get factions filtered by ally (labels only)
GET {{base}}/factions?pred=ally&obj=Rohan&allData=false

### Get factions filtered by enemy
GET {{base}}/factions?pred=enemy&obj=Mordor

### Get faction by name
GET {{base}}/factions/FellowshipOfTheRing

### Get faction by name (not found)
GET {{base}}/factions/Rhun

### Add faction
POST {{base}}/factions
Content-Type: application/json

{
  "name": "NazgulArmy",
  "leader": "Sauron",
  "ally": ["Mordor", "Isengard"],
  "enemy": ["FellowshipOfTheRing", "Gondor"]
}

### Add faction - invalid leader
POST {{base}}/factions
Content-Type: application/json

{
  "name": "Rhun",
  "leader": "Khamul"
}

### Update faction
PUT {{base}}/factions/NazgulArmy
Content-Type: application/json

{
  "name": "NazgulArmy",
  "enemy": ["FellowshipOfTheRing", "Gondor", "Rohan"]
}


# =============================================
# HEALTH
# =============================================

### Health check
GET http://localhost:8000/health
