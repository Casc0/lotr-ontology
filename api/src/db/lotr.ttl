@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix lotr: <http://example.org/lotr/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema: <https://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

lotr:Aragorn a lotr:Character ;
    rdfs:label "Aragorn" ;
    lotr:race lotr:Human ;
    foaf:givenName "Aragorn" ;
    schema:affiliation lotr:FellowshipOfTheRing,
        lotr:Gondor ;
    schema:alternateName "Elessar",
        "Strider" ;
    schema:birthplace lotr:Rivendell .

lotr:BlackGate a lotr:Place ;
    rdfs:label "BlackGate" ;
    lotr:territoryOf lotr:Mordor .

lotr:Boromir a lotr:Character ;
    rdfs:label "Boromir" ;
    lotr:race lotr:Human ;
    foaf:familyName "Denethor" ;
    foaf:givenName "Boromir" ;
    schema:affiliation lotr:Gondor ;
    schema:alternateName "Son of Denethor" ;
    schema:birthplace lotr:MinasTirith .

lotr:Ent a lotr:Race ;
    rdfs:label "Ent" ;
    lotr:longevity 5000 ;
    schema:knowsLanguage "Entish" .

lotr:Eomer a lotr:Character ;
    rdfs:label "Eomer" ;
    lotr:race lotr:Human ;
    foaf:givenName "Eomer" ;
    schema:affiliation lotr:Rohan ;
    schema:birthplace lotr:Edoras .

lotr:Frodo a lotr:Character ;
    rdfs:label "Frodo" ;
    lotr:race lotr:Hobbit ;
    foaf:familyName "Baggins" ;
    foaf:givenName "Frodo" ;
    schema:affiliation lotr:FellowshipOfTheRing ;
    schema:birthplace lotr:Shire .

lotr:Gimli a lotr:Character ;
    rdfs:label "Gimli" ;
    lotr:race lotr:Dwarf ;
    foaf:givenName "Gimli" ;
    schema:affiliation lotr:FellowshipOfTheRing ;
    schema:birthplace lotr:Erebor .

lotr:Legolas a lotr:Character ;
    rdfs:label "Legolas" ;
    lotr:race lotr:Elf ;
    foaf:givenName "Legolas" ;
    schema:affiliation lotr:FellowshipOfTheRing,
        lotr:WoodlandRealm ;
    schema:alternateName "Greenleaf" ;
    schema:birthplace lotr:Mirkwood .

lotr:NazgulArmy a lotr:Faction ;
    rdfs:label "NazgulArmy" ;
    lotr:ally lotr:Isengard,
        lotr:Mordor ;
    lotr:enemy lotr:FellowshipOfTheRing,
        lotr:Gondor,
        lotr:Rohan ;
    lotr:leader lotr:Sauron .

lotr:ally a owl:ObjectProperty ;
    rdfs:label "ally" ;
    rdfs:domain lotr:Faction ;
    rdfs:range lotr:Faction .

lotr:enemy a owl:ObjectProperty ;
    rdfs:label "enemy" ;
    rdfs:domain lotr:Faction ;
    rdfs:range lotr:Faction .

lotr:leader a owl:ObjectProperty ;
    rdfs:label "leader" ;
    rdfs:domain lotr:Faction ;
    rdfs:range lotr:Character ;
    rdfs:subPropertyOf schema:owner .

lotr:longevity a owl:DatatypeProperty ;
    rdfs:label "longevity" ;
    rdfs:domain lotr:Race ;
    rdfs:range xsd:integer .

lotr:race a owl:ObjectProperty ;
    rdfs:label "race" ;
    rdfs:domain lotr:Character ;
    rdfs:range lotr:Race .

lotr:territoryOf a owl:ObjectProperty ;
    rdfs:label "territoryOf" ;
    rdfs:domain lotr:Place ;
    rdfs:range lotr:Faction ;
    rdfs:subPropertyOf schema:location .

lotr:Dwarf a lotr:Race ;
    rdfs:label "Dwarf" ;
    lotr:longevity 250 ;
    schema:knowsLanguage "Khuzdul" .

lotr:Edoras a lotr:Place ;
    rdfs:label "Edoras" ;
    lotr:territoryOf lotr:Rohan .

lotr:Elf a lotr:Race ;
    rdfs:label "Elf" ;
    lotr:longevity 9999 ;
    schema:knowsLanguage "Sindarin" .

lotr:Erebor a lotr:Place ;
    rdfs:label "Erebor" ;
    lotr:territoryOf lotr:Gondor .

lotr:FreePeoples a lotr:Place ;
    rdfs:label "FreePeoples" .

lotr:Gandalf a lotr:Character ;
    rdfs:label "Gandalf" ;
    lotr:race lotr:Maia ;
    foaf:givenName "Gandalf" ;
    schema:affiliation lotr:FellowshipOfTheRing ;
    schema:alternateName "Mithrandir",
        "the Grey" ;
    schema:birthplace lotr:Valinor .

lotr:Hobbit a lotr:Race ;
    rdfs:label "Hobbit" ;
    lotr:longevity 130 ;
    schema:knowsLanguage "Westron" .

lotr:MinasTirith a lotr:Place ;
    rdfs:label "MinasTirith" ;
    lotr:territoryOf lotr:Gondor .

lotr:Mirkwood a lotr:Place ;
    rdfs:label "Mirkwood" ;
    lotr:territoryOf lotr:WoodlandRealm .

lotr:Saruman a lotr:Character ;
    rdfs:label "Saruman" ;
    lotr:race lotr:Maia ;
    foaf:givenName "Saruman" ;
    schema:affiliation lotr:Isengard ;
    schema:alternateName "Curunir",
        "the White" ;
    schema:birthplace lotr:Valinor .

lotr:Shire a lotr:Place ;
    rdfs:label "Shire" ;
    lotr:territoryOf lotr:FreePeoples .

lotr:Sauron a lotr:Character ;
    rdfs:label "Sauron" ;
    lotr:race lotr:Maia ;
    foaf:givenName "Sauron" ;
    schema:affiliation lotr:Mordor ;
    schema:alternateName "Mairon" ;
    schema:birthplace lotr:Valinor .

lotr:Human a lotr:Race ;
    rdfs:label "Human" ;
    lotr:longevity 90 ;
    schema:knowsLanguage "Westron" .

lotr:Maia a lotr:Race ;
    rdfs:label "Maia" ;
    lotr:longevity 9999 ;
    schema:knowsLanguage "Valarin" .

lotr:Isengard a lotr:Faction ;
    rdfs:label "Isengard" ;
    lotr:ally lotr:Mordor ;
    lotr:enemy lotr:FellowshipOfTheRing,
        lotr:Rohan,
        lotr:WoodlandRealm ;
    lotr:leader lotr:Saruman .

lotr:WoodlandRealm a lotr:Faction ;
    rdfs:label "WoodlandRealm" ;
    lotr:ally lotr:FellowshipOfTheRing,
        lotr:Gondor,
        lotr:Rohan ;
    lotr:enemy lotr:Isengard,
        lotr:Mordor ;
    lotr:leader lotr:Thranduil .

lotr:Mordor a lotr:Faction ;
    rdfs:label "Mordor" ;
    lotr:ally lotr:Isengard ;
    lotr:enemy lotr:FellowshipOfTheRing,
        lotr:Gondor,
        lotr:Rohan,
        lotr:WoodlandRealm ;
    lotr:leader lotr:Sauron .

lotr:Place a owl:Class ;
    rdfs:equivalentClass schema:Place .

lotr:Race a owl:Class .

lotr:Rohan a lotr:Faction ;
    rdfs:label "Rohan" ;
    lotr:ally lotr:FellowshipOfTheRing,
        lotr:Gondor,
        lotr:WoodlandRealm ;
    lotr:enemy lotr:Isengard,
        lotr:Mordor ;
    lotr:leader lotr:Theoden .

lotr:Gondor a lotr:Faction ;
    rdfs:label "Gondor" ;
    lotr:ally lotr:FellowshipOfTheRing,
        lotr:Rohan,
        lotr:WoodlandRealm ;
    lotr:enemy lotr:Mordor ;
    lotr:leader lotr:Denethor .

lotr:Character a owl:Class ;
    rdfs:subClassOf foaf:Person .

lotr:FellowshipOfTheRing a lotr:Faction ;
    rdfs:label "FellowshipOfTheRing" ;
    lotr:ally lotr:Gondor,
        lotr:Rohan,
        lotr:WoodlandRealm ;
    lotr:enemy lotr:Isengard,
        lotr:Mordor ;
    lotr:leader lotr:Gandalf .

lotr:Faction a owl:Class ;
    rdfs:subClassOf schema:Organization .

